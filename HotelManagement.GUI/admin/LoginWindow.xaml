<Window x:Class="HotelManagement.GUI.admin.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Đăng nhập quản trị"
        Height="520"
        Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="28">
        <Border Padding="32"
                Background="White"
                CornerRadius="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="26" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               Text="Đăng nhập quản trị" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="#64748B"
                               Text="Vui lòng nhập email và mật khẩu để truy cập hệ thống." />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Margin="0,0,0,8"
                               FontWeight="SemiBold"
                               Foreground="#334155"
                               Text="Email" />
                    <TextBox x:Name="txtEmail"
                             Height="42"
                             Padding="12,8"
                             VerticalContentAlignment="Center"
                             FontSize="15" />
                </StackPanel>

                <StackPanel Grid.Row="4">
                    <TextBlock Margin="0,0,0,8"
                               FontWeight="SemiBold"
                               Foreground="#334155"
                               Text="Mật khẩu" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>

                        <PasswordBox x:Name="pwdPassword"
                                     Grid.Column="0"
                                     Height="42"
                                     Padding="12,8"
                                     FontSize="15"
                                     PasswordChanged="PwdPassword_PasswordChanged" />
                        <TextBox x:Name="txtVisiblePassword"
                                 Grid.Column="0"
                                 Height="42"
                                 Padding="12,8"
                                 VerticalContentAlignment="Center"
                                 FontSize="15"
                                 TextChanged="TxtVisiblePassword_TextChanged"
                                 Visibility="Collapsed" />
                        <Button x:Name="btnTogglePassword"
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                Click="BtnTogglePassword_Click"
                                Content="Hiện"
                                Background="#E2E8F0"
                                BorderBrush="#CBD5E1"
                                Foreground="#0F172A" />
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="6"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Width="120"
                            Height="42"
                            Margin="0,0,12,0"
                            Click="BtnDangNhap_Click"
                            Content="Đăng nhập"
                            Background="#0F766E"
                            Foreground="White"
                            BorderBrush="#0F766E"
                            FontWeight="SemiBold" />
                    <Button Width="100"
                            Height="42"
                            Click="BtnThoat_Click"
                            Content="Thoát"
                            Background="#E2E8F0"
                            BorderBrush="#CBD5E1"
                            Foreground="#0F172A" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
