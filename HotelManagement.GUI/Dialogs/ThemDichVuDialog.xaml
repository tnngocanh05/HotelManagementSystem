<Window x:Class="HotelManagement.GUI.Dialogs.ThemDichVuDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#80000000"
        WindowStartupLocation="CenterScreen"
        Width="500" Height="500">

    <Grid>
        <Border Background="White"
                CornerRadius="15"
                Padding="20"
                Width="400"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="+ Thêm dịch vụ"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <TextBlock Text="Tên dịch vụ"/>
                <TextBox x:Name="txtTen" Margin="0,5,0,10"/>

                <TextBlock Text="Giá"/>
                <TextBox x:Name="txtGia" Margin="0,5,0,10"/>

                <TextBlock Text="Loại dịch vụ"/>
                <ComboBox x:Name="cbLoai" Margin="0,5,0,10">
                    <ComboBoxItem Content="Spa"/>
                    <ComboBoxItem Content="Ăn uống"/>
                    <ComboBoxItem Content="Giặt ủi"/>
                </ComboBox>

                <TextBlock Text="Mã dịch vụ"/>
                <TextBox x:Name="txtMa"
         Margin="0,5,0,10"
         IsReadOnly="True"
         Background="#EEE"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="Hủy"
                            Width="80"
                            Margin="5"
                            Click="btnHuy_Click"/>

                    <Button Content="Lưu"
                            Width="80"
                            Margin="5"
                            Background="#3B82F6"
                            Foreground="White"
                            Click="btnLuu_Click"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>