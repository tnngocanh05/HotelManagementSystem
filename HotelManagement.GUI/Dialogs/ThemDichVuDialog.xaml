<Window x:Class="HotelManagement.GUI.Dialogs.ThemDichVuDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm dịch vụ"
        Height="350"
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5FBFB">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="THÊM DỊCH VỤ"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#0F4C5C"
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Mã đặt phòng:" VerticalAlignment="Center"/>
                <TextBox x:Name="txtMaDatPhong" Grid.Column="1" IsReadOnly="True"/>

                <TextBlock Text="Dịch vụ:" Grid.Row="1" VerticalAlignment="Center"/>
                <ComboBox x:Name="cbDichVu" Grid.Row="1" Grid.Column="1"
                          DisplayMemberPath="TenDichVu"
                          SelectedValuePath="MaDichVu"/>

                <TextBlock Text="Số lượng:" Grid.Row="2" VerticalAlignment="Center"/>
                <TextBox x:Name="txtSoLuong" Grid.Row="2" Grid.Column="1"/>

                <TextBlock Text="Đơn giá:" Grid.Row="3" VerticalAlignment="Center"/>
                <TextBox x:Name="txtDonGia" Grid.Row="3" Grid.Column="1" IsReadOnly="True"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button x:Name="btnLuu"
                    Content="Lưu"
                    Width="120"
                    Margin="10,0"/>

            <Button x:Name="btnDong"
                    Content="Đóng"
                    Width="120"
                    Margin="10,0"/>
        </StackPanel>
    </Grid>
</Window>