<Window x:Class="HotelManagement.GUI.Views.NhanVienDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông tin nhân viên" Height="550" Width="450" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Họ và tên:" Margin="0,5"/>
            <TextBox x:Name="txtHoTen" Height="30"/>

            <TextBlock Text="Ngày sinh:" Margin="0,10,0,5"/>
            <DatePicker x:Name="dpNgaySinh" Height="30"/>

            <TextBlock Text="Giới tính:" Margin="0,10,0,5"/>
            <ComboBox x:Name="cbGioiTinh" Height="30">
                <ComboBoxItem Content="Nam" IsSelected="True"/>
                <ComboBoxItem Content="Nữ"/>
                <ComboBoxItem Content="Khác"/>
            </ComboBox>

            <TextBlock Text="Số điện thoại:" Margin="0,10,0,5"/>
            <TextBox x:Name="txtSDT" Height="30"/>

            <TextBlock Text="Số CCCD:" Margin="0,10,0,5"/>
            <TextBox x:Name="txtCCCD" Height="30"/>

            <TextBlock Text="Email:" Margin="0,10,0,5"/>
            <TextBox x:Name="txtEmail" Height="30"/>

            <TextBlock Text="Mã chức vụ:" Margin="0,10,0,5"/>
            <TextBox x:Name="txtMaChucVu" Height="30"/>

            <UniformGrid Columns="2" Margin="0,25,0,0">
                <Button Content="Lưu" Click="BtnLuu_Click" Height="35" Background="#2ecc71" Foreground="White" Margin="0,0,5,0" BorderThickness="0"/>
                <Button Content="Hủy" Click="BtnHuy_Click" Height="35" Background="#95a5a6" Foreground="White" Margin="5,0,0,0" BorderThickness="0"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>