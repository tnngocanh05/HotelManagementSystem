<Window x:Class="HotelManagement.GUI.Dialogs.LoaiPhongDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông tin loại phòng" Height="374" Width="450" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="QUẢN LÝ LOẠI PHÒNG" FontSize="20" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#2c3e50"/>

            <TextBlock Text="Tên loại phòng:"/>
            <TextBox x:Name="txtTenLoaiPhong" Margin="0,5,0,15" Padding="5" Height="30"/>

            <TextBlock Text="Số người tối đa:"/>
            <TextBox x:Name="txtSoNguoiToiDa" Margin="0,5,0,15" Padding="5" Height="30"/>

            <TextBlock Text="Giá phòng (VNĐ):"/>
            <TextBox x:Name="txtGiaTien" Margin="0,5,0,15" Padding="5" Height="30"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="btnLuu" Content="Lưu lại" Width="100" Height="30" 
                        Click="BtnLuu_Click" Background="#2ecc71" Foreground="White" Margin="0,0,10,0"/>
                <Button x:Name="btnHuy" Content="Hủy bỏ" Width="100" Height="30" 
                        Click="BtnHuy_Click" Background="#e74c3c" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>