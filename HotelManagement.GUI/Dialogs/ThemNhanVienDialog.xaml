<Window x:Class="HotelManagement.GUI.Dialogs.ThemNhanVienDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#80000000"
        WindowStartupLocation="CenterScreen"
        Width="500" Height="600">

    <Grid>
        <!-- FORM -->
        <Border Background="White"
                CornerRadius="15"
                Padding="20"
                Width="400"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <!-- SCROLL để không bao giờ bị che -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel>

                    <TextBlock Text="+ Thêm nhân viên"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="Họ tên"/>
                    <TextBox x:Name="txtHoTen" Height="30" Margin="0,5,0,10"/>

                    <TextBlock Text="Ngày sinh"/>
                    <DatePicker x:Name="dpNgaySinh" Margin="0,5,0,10"/>

                    <TextBlock Text="Giới tính"/>
                    <ComboBox x:Name="cbGioiTinh" Margin="0,5,0,10">
                        <ComboBoxItem Content="Nam"/>
                        <ComboBoxItem Content="Nữ"/>
                    </ComboBox>

                    <TextBlock Text="SĐT"/>
                    <TextBox x:Name="txtSDT" Height="30" Margin="0,5,0,10"/>

                    <TextBlock Text="CCCD"/>
                    <TextBox x:Name="txtCCCD" Height="30" Margin="0,5,0,10"/>

                    <TextBlock Text="Email"/>
                    <TextBox x:Name="txtEmail" Height="30" Margin="0,5,0,10"/>

                    <TextBlock Text="Chức vụ"/>
                    <ComboBox x:Name="cbChucVu" Margin="0,5,0,15"/>

                    <!-- NÚT -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,10,0,0">

                        <Button Content="Hủy"
                                Width="80"
                                Margin="5"
                                Click="btnHuy_Click"/>

                        <Button Content="Lưu"
                                Width="80"
                                Margin="5"
                                Background="#3B82F6"
                                Foreground="White"
                                Click="btnLuu_Click"/>
                    </StackPanel>

                </StackPanel>

            </ScrollViewer>

        </Border>
    </Grid>
</Window>
