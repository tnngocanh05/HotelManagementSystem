<Window x:Class="HotelManagement.GUI.Dialogs.DatPhongDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Đặt phòng"
        Height="620"
        Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5FBFB">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <TextBlock Text="THÔNG TIN ĐẶT PHÒNG"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#0F4C5C"
                   Margin="0,0,0,20"/>

        <!-- Form nhập -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Mã phòng:" VerticalAlignment="Center"/>
                <TextBox x:Name="txtMaPhong" Grid.Column="1" IsReadOnly="True"/>

                <TextBlock Text="Loại phòng:" Grid.Row="1" VerticalAlignment="Center"/>
                <TextBox x:Name="txtLoaiPhong" Grid.Row="1" Grid.Column="1" IsReadOnly="True"/>

                <TextBlock Text="Họ tên khách:" Grid.Row="2" VerticalAlignment="Center"/>
                <TextBox x:Name="txtHoTen" Grid.Row="2" Grid.Column="1"/>

                <TextBlock Text="CCCD:" Grid.Row="3" VerticalAlignment="Center"/>
                <TextBox x:Name="txtCCCD" Grid.Row="3" Grid.Column="1"/>

                <TextBlock Text="SĐT:" Grid.Row="4" VerticalAlignment="Center"/>
                <TextBox x:Name="txtSDT" Grid.Row="4" Grid.Column="1"/>

                <TextBlock Text="Số người:" Grid.Row="5" VerticalAlignment="Center"/>
                <TextBox x:Name="txtSoNguoi" Grid.Row="5" Grid.Column="1"/>

                <TextBlock Text="Ngày nhận:" Grid.Row="6" VerticalAlignment="Center"/>
                <DatePicker x:Name="dpNgayNhan" Grid.Row="6" Grid.Column="1"/>

                <TextBlock Text="Giờ nhận:" Grid.Row="7" VerticalAlignment="Center"/>
                <ComboBox x:Name="cbGioNhan" Grid.Row="7" Grid.Column="1"/>

                <TextBlock Text="Ngày trả dự kiến:" Grid.Row="8" VerticalAlignment="Center"/>
                <DatePicker x:Name="dpNgayTra" Grid.Row="8" Grid.Column="1"/>
            </Grid>
        </Border>

        <!-- Nút -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button x:Name="btnDatPhong"
                    Content="Đặt phòng"
                    Width="120"
                    Background="#1B6CA8"
                    Foreground="White"
                    Margin="10,0"/>

            <Button x:Name="btnDong"
                    Content="Đóng"
                    Width="120"
                    Background="#9E9E9E"
                    Foreground="White"
                    Margin="10,0"/>
        </StackPanel>
    </Grid>
</Window>