<Window x:Class="HotelManagement.GUI.Dialogs.ThemKhachHangDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#80000000"
        WindowStartupLocation="CenterScreen"
        Width="500" Height="350">

    <Grid>

        <!-- FORM -->
        <Border Background="White"
                CornerRadius="15"
                Padding="20"
                Width="400"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <!-- SCROLL giống nhân viên -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel>

                    <!-- TITLE -->
                    <TextBlock Text="+ Thêm khách hàng"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <!-- HỌ TÊN -->
                    <TextBlock Text="Họ tên"/>
                    <TextBox x:Name="txtHoTen"
                             Height="30"
                             Margin="0,5,0,10"/>

                    <!-- CCCD -->
                    <TextBlock Text="CCCD"/>
                    <TextBox x:Name="txtCCCD"
                             Height="30"
                             Margin="0,5,0,10"/>

                    <!-- SĐT -->
                    <TextBlock Text="Số điện thoại"/>
                    <TextBox x:Name="txtSDT"
                             Height="30"
                             Margin="0,5,0,15"/>

                    <!-- NÚT -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,10,0,0">

                        <Button Content="Hủy"
                                Width="80"
                                Margin="5"
                                Click="btnHuy_Click"/>

                        <Button Content="Lưu"
                                Width="80"
                                Margin="5"
                                Background="#3B82F6"
                                Foreground="White"
                                Click="btnLuu_Click"/>

                    </StackPanel>

                </StackPanel>

            </ScrollViewer>

        </Border>

    </Grid>
</Window>