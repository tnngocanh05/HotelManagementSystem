<Window x:Class="HotelManagement.GUI.Dialogs.ThanhToanChuyenKhoanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thanh toán chuyển khoản"
        Height="680"
        Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5FBFB">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="THANH TOÁN VNPAY DEMO"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#0F4C5C"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Mã giao dịch:" VerticalAlignment="Center"/>
                <TextBox x:Name="txtMaGiaoDich" Grid.Column="1" IsReadOnly="True"/>

                <TextBlock Text="Mã đặt phòng:" Grid.Row="1" VerticalAlignment="Center"/>
                <TextBox x:Name="txtMaDatPhong" Grid.Row="1" Grid.Column="1" IsReadOnly="True"/>

                <TextBlock Text="Số tiền:" Grid.Row="2" VerticalAlignment="Center"/>
                <TextBox x:Name="txtSoTien" Grid.Row="2" Grid.Column="1" IsReadOnly="True"
                         FontWeight="Bold"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,0,15">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="MÃ QR VNPAY DEMO"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#0F4C5C"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <Border Width="240"
                        Height="240"
                        BorderBrush="#0F4C5C"
                        BorderThickness="2"
                        Background="White"
                        Padding="10"
                        HorizontalAlignment="Center">
                    <Image x:Name="imgQR"
                           Width="220"
                           Height="220"
                           Stretch="Fill"/>
                </Border>

                <TextBlock x:Name="txtTrangThai"
                           Text="Trạng thái: Chờ thanh toán"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="DarkOrange"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">
            <Button x:Name="btnGiaLapThanhCong"
                    Content="Giả lập quét thành công"
                    Width="170"
                    Margin="10,0"/>

            <Button x:Name="btnHoanTat"
                    Content="Hoàn tất thanh toán"
                    Width="150"
                    Margin="10,0"
                    IsEnabled="False"/>

            <Button x:Name="btnDong"
                    Content="Đóng"
                    Width="100"
                    Margin="10,0"/>
        </StackPanel>
    </Grid>
</Window>