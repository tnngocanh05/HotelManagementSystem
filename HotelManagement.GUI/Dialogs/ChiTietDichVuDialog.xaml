<Window x:Class="HotelManagement.GUI.Views.ChiTietDichVuDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm Dịch Vụ Vào Phòng" Height="350" Width="400" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="THÊM DỊCH VỤ" FontSize="20" FontWeight="Bold" Foreground="#2c3e50" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Chọn loại dịch vụ:" Margin="0,5"/>
            <ComboBox x:Name="cbDichVu" Height="35" 
                      DisplayMemberPath="TenDichVu" 
                      SelectedValuePath="MaDichVu"/>

            <TextBlock Text="Số lượng sử dụng:" Margin="0,15,0,5"/>
            <TextBox x:Name="txtSoLuong" Text="1" Height="35" VerticalContentAlignment="Center" FontSize="16"/>

            <UniformGrid Columns="2" Margin="0,25,0,0">
                <Button Content="XÁC NHẬN" Click="BtnXacNhan_Click" Height="45" Background="#f1c40f" Foreground="White" FontWeight="Bold" Margin="0,0,5,0" BorderThickness="0"/>
                <Button Content="ĐÓNG" Click="BtnHuy_Click" Height="45" Background="#95a5a6" Foreground="White" FontWeight="Bold" Margin="5,0,0,0" BorderThickness="0"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>