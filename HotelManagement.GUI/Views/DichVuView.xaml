<UserControl x:Class="HotelManagement.GUI.Views.DichVuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="Thêm dịch vụ mới" Click="BtnThem_Click" Width="150" Height="35" 
                    Background="#2ecc71" Foreground="White" BorderThickness="0"/>
        </StackPanel>

        <DataGrid x:Name="dgDichVu" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                  CanUserAddRows="False" RowHeight="40" Background="Transparent">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã" Binding="{Binding MaDichVu}" Width="60"/>
                <DataGridTextColumn Header="Tên Dịch Vụ" Binding="{Binding TenDichVu}" Width="*"/>
                <DataGridTextColumn Header="Đơn Giá" Binding="{Binding DonGia, StringFormat={}{0:N0} VNĐ}" Width="150"/>
                <DataGridTextColumn Header="Loại Dịch Vụ" Binding="{Binding LoaiDichVu}" Width="150"/>

                <DataGridTemplateColumn Header="Hành động" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Sửa" Click="BtnSua_Click" Margin="0,0,5,0" 
                                        Background="#3498db" Foreground="White" Padding="12,2" BorderThickness="0"/>
                                <Button Content="Xóa" Click="BtnXoa_Click" Margin="0,0,5,0"
                                        Background="#e74c3c" Foreground="White" Padding="12,2" BorderThickness="0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>