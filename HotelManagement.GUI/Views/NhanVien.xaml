<UserControl x:Class="HotelManagement.GUI.Views.NhanVien"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="#F5F6FA">

    <!-- KHÔNG set Width/Height ở root -->
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="20,20,20,0">
            <TextBlock Text="👥 Quản lý nhân viên"
                       Foreground="#104F7A"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Button Content="+ Thêm nhân viên"
                    Width="150"
                    Height="35"
                    HorizontalAlignment="Right"
                    Background="#104F7A"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="btnThemNhanVien_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <!-- TABLE -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                Padding="5"
                Margin="20">

            <DataGrid x:Name="dgNhanVien"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      BorderThickness="0"
                      Background="White"
                      RowHeight="40"
                      ColumnHeaderHeight="45">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="Foreground" Value="#104F7A"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#DDD"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>

                    <!-- MÃ NV -->
                    <DataGridTextColumn Header="MÃ NV"
                                        Binding="{Binding MaNV}"
                                        Width="100"/>

                    <!-- HỌ TÊN (giảm lại để không đẩy cột khác đi xa) -->
                    <DataGridTextColumn Header="HỌ TÊN"
                                        Binding="{Binding HoTen}"
                                        Width="2*"/>

                    <!-- CHỨC VỤ (gần lại + fix binding) -->
                    <DataGridTextColumn Header="CHỨC VỤ"
                                        Binding="{Binding MaChucVu}"
                                        Width="1*"/>

                    <!-- ACTION -->
                    <DataGridTemplateColumn Header="HÀNH ĐỘNG"
                                            Width="180">

                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">

                                    <Button Content="Sửa"
                                            Background="Transparent"
                                            Foreground="#3498DB"
                                            BorderThickness="0"
                                            FontWeight="SemiBold"
                                            Margin="5,0"
                                            Click="btnSua_Click"/>

                                    <TextBlock Text="|" VerticalAlignment="Center" Foreground="#DDD"/>

                                    <Button Content="Xóa"
                                            Background="Transparent"
                                            Foreground="#E74C3C"
                                            BorderThickness="0"
                                            FontWeight="SemiBold"
                                            Margin="5,0"
                                            Click="btnXoa_Click"/>

                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>

                    </DataGridTemplateColumn>

                </DataGrid.Columns>

            </DataGrid>
        </Border>
    </Grid>
</UserControl>