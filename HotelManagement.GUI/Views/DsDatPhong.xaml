<UserControl x:Class="HotelManagement.GUI.Views.DsDatPhong"
        
         xmlns:effects="clr-namespace:System.Windows.Media.Effects;assembly=PresentationCore"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="#F5F6FA">

    <!-- ❌ BỎ sidebar -->
    <!-- ✔ GIỮ content -->

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Text="Danh sách đặt phòng"
                   Foreground="#104F7A"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="5,0,5,15"/>

        <!-- FILTER -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="5"
                Padding="15"
                Margin="5">

            <Border.Effect>
                <effects:DropShadowEffect BlurRadius="10"
                              ShadowDepth="2"
                              Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Tìm kiếm" FontWeight="SemiBold"/>
                    <TextBlock Text="Trạng thái" Grid.Column="1" FontWeight="SemiBold"/>
                    <TextBlock Text="Nhận từ" Grid.Column="2" FontWeight="SemiBold"/>
                    <TextBlock Text="Trả đến" Grid.Column="3" FontWeight="SemiBold"/>
                </Grid>

                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="txtSearch" Height="30" Margin="2"
                             VerticalContentAlignment="Center"/>

                    <ComboBox x:Name="cbTrangThai" Grid.Column="1" Height="30" Margin="5,2">
                        <ComboBoxItem Content="Tất cả" IsSelected="True"/>
                        <ComboBoxItem Content="Đã đặt"/>
                        <ComboBoxItem Content="Đang ở"/>
                    </ComboBox>

                    <DatePicker x:Name="dpFrom" Grid.Column="2" Height="30"/>
                    <DatePicker x:Name="dpTo" Grid.Column="3" Height="30"/>

                    <Button Content="Lọc"
                            Grid.Column="4"
                            Background="#104F7A"
                            Foreground="White"
                            Click="BtnFilter_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- DATAGRID -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="5"
                Margin="5,10,5,5">

            <DataGrid x:Name="dgDatPhong"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã" Binding="{Binding MaDatPhong}" Width="60"/>
                    <DataGridTextColumn Header="Khách" Binding="{Binding MaKhachHang}" Width="*"/>
                    <DataGridTextColumn Header="Phòng" Binding="{Binding MaPhong}" Width="80"/>
                    <DataGridTextColumn Header="Nhận" Binding="{Binding ThoiGianNhan}" Width="150"/>
                    <DataGridTextColumn Header="Trả" Binding="{Binding NgayTraDuKien}" Width="150"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="120"/>
                </DataGrid.Columns>


            </DataGrid>
        </Border>

    </Grid>
</UserControl>