<UserControl x:Class="HotelManagement.GUI.Views.ThongKeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             Background="#F8F9FA">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="BÁO CÁO THỐNG KÊ CHI TIẾT" 
                       FontSize="24" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,15"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Từ ngày:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker x:Name="dpTuNgay" Width="150" Margin="0,0,20,0"/>
                <TextBlock Text="Đến ngày:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker x:Name="dpDenNgay" Width="150" Margin="0,0,20,0"/>

                <Button Content="CẬP NHẬT DỮ LIỆU" Click="BtnThongKe_Click" 
                        Padding="15,5" Background="#3498db" Foreground="White" FontWeight="Bold" Margin="0,0,10,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="XUẤT PDF" Click="BtnXuatPDF_Click" 
                        Padding="15,5" Background="#e67e22" Foreground="White" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,20">
                <Border Background="#4776E6" CornerRadius="10" Padding="15" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Tổng doanh thu" Foreground="White" FontSize="13"/>
                        <TextBlock x:Name="txtDoanhThu" Text="0 đ" Foreground="White" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#2ecc71" CornerRadius="10" Padding="15" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Phòng hiện có" Foreground="White" FontSize="13"/>
                        <TextBlock x:Name="txtSoPhong" Text="--" Foreground="White" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#f39c12" CornerRadius="10" Padding="15" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Dịch vụ đã bán" Foreground="White" FontSize="13"/>
                        <TextBlock x:Name="txtDichVu" Text="--" Foreground="White" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="3" Background="White" CornerRadius="15" Padding="20" Margin="5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#DCDCDC" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="BIỂU ĐỒ DOANH THU (VNĐ)" FontWeight="Bold" Foreground="#34495e" Margin="0,0,0,15"/>
                    <lvc:CartesianChart Height="350" Series="{Binding RevenueSeries}" LegendLocation="None">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="Thời gian" Labels="{Binding Labels}">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Step="1" IsEnabled="False"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisX>

                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="Số tiền (VND)" 
                                      LabelFormatter="{Binding YFormatter}"
                                      MinValue="0" 
                                      MaxValue="100000000">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Step="20000000" StrokeThickness="0.5" Stroke="#E0E0E0"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </StackPanel>
            </Border>

            <UniformGrid Grid.Row="4" Columns="2" Margin="0,10,0,0">
                <Border Background="White" CornerRadius="15" Padding="15" Margin="5">
                    <StackPanel>
                        <TextBlock Text="TÌNH TRẠNG PHÒNG" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="#34495e"/>
                        <lvc:PieChart Height="250" Series="{Binding StatusSeries}" LegendLocation="Bottom" InnerRadius="50"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="15" Padding="15" Margin="5">
                    <StackPanel>
                        <TextBlock Text="TỶ LỆ DỊCH VỤ" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="#34495e"/>
                        <lvc:PieChart Height="250" Series="{Binding ServiceSeries}" LegendLocation="Bottom" InnerRadius="50"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </ScrollViewer>
</UserControl>