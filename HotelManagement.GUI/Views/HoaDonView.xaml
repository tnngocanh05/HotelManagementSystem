<UserControl x:Class="HotelManagement.GUI.Views.HoaDonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F5FBFB" Height="853" Width="1550">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TIÊU ĐỀ -->
        <Border Grid.Row="0"
                Background="#2F86A6"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <TextBlock Text="QUẢN LÝ HÓA ĐƠN"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="White"/>
        </Border>

        <!-- BỘ LỌC -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <!-- Dòng 1 -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Từ ngày:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <DatePicker x:Name="dpTuNgay"
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="5"
                            Height="32"/>

                <TextBlock Grid.Row="0" Grid.Column="2"
                           Text="Đến ngày:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <DatePicker x:Name="dpDenNgay"
                            Grid.Row="0"
                            Grid.Column="3"
                            Margin="5"
                            Height="32"/>

                <TextBlock Grid.Row="0" Grid.Column="4"
                           Text="Trạng thái:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <ComboBox x:Name="cbTrangThai"
                          Grid.Row="0"
                          Grid.Column="5"
                          Margin="5"
                          Height="32"/>

                <TextBlock Grid.Row="0" Grid.Column="6"
                           Text="Tìm kiếm:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <TextBox x:Name="txtKeyword"
                         Grid.Row="0"
                         Grid.Column="7"
                         Margin="5"
                         Height="32"
                         VerticalContentAlignment="Center"
                         ToolTip="Nhập mã phòng, SĐT, CCCD hoặc họ tên"/>

                <!-- Dòng 2 - Nút -->
                <StackPanel Grid.Row="1"
                            Grid.ColumnSpan="8"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0">

                    <Button x:Name="btnTimKiem"
                            Content="Tìm kiếm"
                            Width="110"
                            Height="36"
                            Margin="5"
                            Background="#2F86A6"
                            Foreground="White"
                            FontWeight="SemiBold"/>

                    <Button x:Name="btnLamMoi"
                            Content="Làm mới"
                            Width="110"
                            Height="36"
                            Margin="5"
                            Background="#6C757D"
                            Foreground="White"
                            FontWeight="SemiBold"/>

                    <Button x:Name="btnXemChiTiet"
                            Content="Xem chi tiết"
                            Width="120"
                            Height="36"
                            Margin="5"
                            Background="#198754"
                            Foreground="White"
                            FontWeight="SemiBold"/>

                    <Button x:Name="btnXuatExcel"
                            Content="Xuất Excel"
                            Width="120"
                            Height="36"
                            Margin="5"
                            Background="#0D6EFD"
                            Foreground="White"
                            FontWeight="SemiBold"/>

                    <Button x:Name="btnXuatPDF"
                            Content="Xuất PDF"
                            Width="120"
                            Height="36"
                            Margin="5"
                            Background="#DC3545"
                            Foreground="White"
                            FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BẢNG HÓA ĐƠN -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="15">
            <DataGrid x:Name="dgHoaDon"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      RowHeight="35"
                      FontSize="14"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F8F9FA">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã HĐ"
                                        Binding="{Binding SoHoaDon}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Mã phòng"
                                        Binding="{Binding SoPhong}"
                                        Width="90"/>

                    <DataGridTextColumn Header="Khách hàng"
                                        Binding="{Binding HoTenKhachHang}"
                                        Width="180"/>

                    <DataGridTextColumn Header="CCCD"
                                        Binding="{Binding CCCD}"
                                        Width="130"/>

                    <DataGridTextColumn Header="SĐT"
                                        Binding="{Binding SDT}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Loại phòng"
                                        Binding="{Binding TenLoaiPhong}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Số đêm"
                                        Binding="{Binding SoDem}"
                                        Width="80"/>

                    <DataGridTextColumn Header="Ngày lập"
                                        Binding="{Binding NgayLap, StringFormat=dd/MM/yyyy HH:mm}"
                                        Width="140"/>

                    <DataGridTextColumn Header="Ngày thanh toán"
                                        Binding="{Binding NgayThanhToan, StringFormat=dd/MM/yyyy HH:mm}"
                                        Width="150"/>

                    <DataGridTextColumn Header="Trạng thái"
                                        Binding="{Binding TrangThai}"
                                        Width="130"/>

                    <DataGridTextColumn Header="Phương thức"
                                        Binding="{Binding PhuongThucThanhToan}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Tổng tiền"
                                        Binding="{Binding TongTien, StringFormat=N0}"
                                        Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>