<UserControl x:Class="HotelManagement.GUI.Views.KhachHangView"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" 
            Background="#F5F6FA" av:DesignHeight="581.081" av:DesignWidth="1307.885">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="20,20,20,10">

            <TextBlock Text="👤 Quản lý khách hàng"
                       Foreground="#104F7A"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Button Content="+ Thêm khách hàng"
                    Width="180"
                    Height="38"
                    HorizontalAlignment="Right"
                    Background="#104F7A"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="btnThemKhachHang_Click">

                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>

            </Button>
        </Grid>

        <!-- TABLE -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="10"
                Margin="20"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <DataGrid x:Name="dgKhachHang"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      BorderThickness="0"
                      Background="White"
                      RowHeight="45"
                      ColumnHeaderHeight="45"
                      GridLinesVisibility="None">

                <!-- HEADER STYLE -->
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="Foreground" Value="#104F7A"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#DDD"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <!-- ROW STYLE -->
                <DataGrid.RowStyle>
                    <Style TargetType="{x:Type DataGridRow}">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F9FAFB"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="MÃ KH"
                                        Binding="{Binding MaKhachHang}"
                                        Width="100"/>

                    <DataGridTextColumn Header="HỌ TÊN"
                                        Binding="{Binding HoTen}"
                                        Width="2*"/>

                    <DataGridTextColumn Header="CCCD"
                                        Binding="{Binding CCCD}"
                                        Width="1.5*"/>

                    <DataGridTextColumn Header="SĐT"
                                        Binding="{Binding SDT}"
                                        Width="1.2*"/>

                    <!-- ACTION -->
                    <DataGridTemplateColumn Header="HÀNH ĐỘNG"
                                            Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">

                                    <Button Content="Sửa"
                                            Background="Transparent"
                                            Foreground="#3B82F6"
                                            BorderThickness="0"
                                            FontWeight="SemiBold"
                                            Cursor="Hand"
                                            Click="btnSua_Click"/>

                                    <TextBlock Text=" | "
                                               Foreground="#DDD"
                                               VerticalAlignment="Center"/>

                                    <Button Content="Xóa"
                                            Background="Transparent"
                                            Foreground="#EF4444"
                                            BorderThickness="0"
                                            FontWeight="SemiBold"
                                            Cursor="Hand"
                                            Click="btnXoa_Click"/>

                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>

            </DataGrid>
        </Border>
    </Grid>
</UserControl>