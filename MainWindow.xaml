<Window x:Class="QuanLyKhachSanWeb.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Trang chủ quản trị"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FFF4F7FB">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="28"
                Background="White"
                CornerRadius="18">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               Text="Trang chủ quản trị" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#64748B"
                               Text="Chọn chức năng để quản lý hệ thống khách sạn." />
                </StackPanel>

                <Button Width="120"
                        Height="40"
                        Click="BtnDangXuat_Click"
                        Content="Đăng xuất"
                        Background="#E2E8F0"
                        BorderBrush="#CBD5E1"
                        Foreground="#0F172A" />
            </DockPanel>
        </Border>

        <UniformGrid Grid.Row="2"
                     Columns="3"
                     Rows="2">
            <Button Margin="10"
                    Padding="24"
                    Click="BtnDatPhong_Click"
                    Content="Đặt phòng"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Background="#0F766E"
                    Foreground="White"
                    BorderBrush="#0F766E" />
            <Button Margin="10"
                    Padding="24"
                    Click="BtnKhachHang_Click"
                    Content="Khách hàng"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Background="#0369A1"
                    Foreground="White"
                    BorderBrush="#0369A1" />
            <Button Margin="10"
                    Padding="24"
                    Click="BtnNhanVien_Click"
                    Content="Nhân viên"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Background="#7C3AED"
                    Foreground="White"
                    BorderBrush="#7C3AED" />
            <Button Margin="10"
                    Padding="24"
                    Click="BtnPhong_Click"
                    Content="Phòng"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Background="#2563EB"
                    Foreground="White"
                    BorderBrush="#2563EB" />
            <Button Margin="10"
                    Padding="24"
                    Click="BtnHoaDon_Click"
                    Content="Hóa đơn"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Background="#EA580C"
                    Foreground="White"
                    BorderBrush="#EA580C" />
            <Button Margin="10"
                    Padding="24"
                    Click="BtnThongKe_Click"
                    Content="Thống kê"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Background="#BE123C"
                    Foreground="White"
                    BorderBrush="#BE123C" />
        </UniformGrid>
    </Grid>
</Window>
